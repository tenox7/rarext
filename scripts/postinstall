#!/bin/bash

chmod -R 755 /Applications/RARExt.app

CONSOLE_USER=$(stat -f "%Su" /dev/console)
sudo -u "$CONSOLE_USER" open -a /Applications/RARExt.app --args --register

sudo -u "$CONSOLE_USER" osascript -e 'display dialog "RARExt has been installed.

To enable the Finder extension:
1. Open RARExt app from Applications

Then either:
2a. Go to System Settings → General → Login Items & Extensions → Extensions → Finder Extensions → Enable RAR

Or:
2b. Right-click a file in Finder → Quick Actions → Customize… → Enable RAR" buttons {"OK"} default button "OK" with title "RARExt"'

exit 0
